# JiraPS Integration Test Environment Configuration
# Copy this file to .env and fill in your values
# The .env file is gitignored and should never be committed

# =============================================================================
# JIRA CLOUD CONNECTION
# =============================================================================

# Your Jira Cloud instance URL (e.g., https://your-company.atlassian.net/)
JIRA_CLOUD_URL=https://your-instance.atlassian.net/

# Your Atlassian account email address
JIRA_CLOUD_USERNAME=your-email@example.com

# API token generated from https://id.atlassian.com/manage-profile/security/api-tokens
# This is NOT your Atlassian account password
JIRA_CLOUD_PASSWORD=your-api-token

# =============================================================================
# TEST FIXTURES
# These should point to resources in your dedicated test project
# =============================================================================

# The project key for your dedicated test project (e.g., TV, TEST, JIRAPS)
JIRA_TEST_PROJECT=TV

# A permanent test issue key that exists in your test project
# This issue is used for read-only tests
JIRA_TEST_ISSUE=TV-1

# Your Atlassian account ID (found in your profile URL or via API)
# Used for user-related tests
JIRA_TEST_USER=557058:12345678-1234-1234-1234-123456789abc

# A group name that exists in your Jira instance
# Used for group membership tests
JIRA_TEST_GROUP=jira-users

# A saved filter ID that exists and is accessible
# Used for filter-related tests
JIRA_TEST_FILTER=10000

# A version name or ID in your test project
# Used for version-related tests
JIRA_TEST_VERSION=1.0.0

# =============================================================================
# OPTIONAL: TEST BEHAVIOR
# =============================================================================

# Set to "true" to skip tests that create/modify/delete resources
# Useful for running read-only tests against production-like environments
# JIRA_TEST_READONLY=false

# Set to "true" to see detailed API call information during tests
# JIRA_TEST_VERBOSE=false

# =============================================================================
# OPTIONAL: NORMAL (NON-ADMIN) USER
# A second user account used for permission-boundary tests. When unset, the
# permission tests in Tests/Integration/Permissions.Integration.Tests.ps1 are
# skipped automatically. The normal user MUST NOT be a Jira administrator.
# =============================================================================

# JIRA_CLOUD_USERNAME_NORMAL=normal-user@example.com
# JIRA_CLOUD_PASSWORD_NORMAL=your-normal-user-api-token
